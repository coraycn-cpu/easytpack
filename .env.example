# 云端账号（新手请先看 docs/SUPABASE_SETUP.md）
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://你的项目.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key
# 管理后台以后再用，现在可留空
SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# ── AI 路由 ──────────────────────────────────────────────
AI_PROVIDER=gateway
AI_GATEWAY_API_KEY=

# 文本 + 看图提炼
AI_MODEL_GATEWAY=google/gemini-2.5-flash

# ── 生图模型选型（测试期推荐）────────────────────────────
# 平铺/背面/领口等（需跟模特图保真）→ Flux Kontext：真正吃参考图并去模特
AI_MODEL_GATEWAY_IMAGE=bfl/flux-kontext-pro
# 线稿：建议也用 Kontext 转线稿（成功率高于 Recraft Utility）
# 若坚持 Recraft：recraft/recraft-v3
AI_MODEL_GATEWAY_IMAGE_LINE_ART=bfl/flux-kontext-pro

# 备选（按场景）：
#   bytedance/seedream-4.5     — 电商/服装平铺备选
#   recraft/recraft-v4.1-utility — 纯文生产品平铺（不吃图，保真弱）
#   xai/grok-imagine-image     — 更便宜的测试平铺
#   prodia/flux-fast-schnell   — 极便宜冒烟测试，质量不够做工艺单
#   openai/gpt-image-1-mini    — 付费升级后可考虑（编辑强，更贵）
#   google/imagen-4.0-fast-*   — 付费升级后高质量摄影平铺

# ── B 区视角图 ────────────────────────────────────────────
AI_IMAGE_PROVIDER=auto
AI_IMAGE_FALLBACK=gateway

SILICONFLOW_API_KEY=
AI_MODEL_SILICONFLOW_IMAGE=Qwen/Qwen-Image-Edit-2509

DASHSCOPE_API_KEY=
AI_MODEL_DASHSCOPE=qwen-plus
ZHIPU_API_KEY=
AI_MODEL_ZHIPU=glm-4-flash
