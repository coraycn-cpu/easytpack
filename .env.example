# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://你的项目.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key
SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# ── AI 路由 ──────────────────────────────────────────────
# gateway = 走 Vercel AI Gateway（推荐，文本 + 生图均可）
AI_PROVIDER=gateway

# Vercel AI Gateway
# 在线测试：在 Vercel 项目 Settings → Environment Variables 配置（Production / Preview 均勾选）
# 部署后 push 触发构建，在 https://你的域名/debug/ai 验证生图
# 同项目部署在 Vercel 上时，也可依赖 OIDC 自动鉴权（可不填 Key，但显式配置 Key 更稳）
AI_GATEWAY_API_KEY=

# 文本/结构化任务 + 有参考图时「看图提炼」用（非生图）
AI_MODEL_GATEWAY=google/gemini-2.5-flash

# Gateway 生图：当前统一 Recraft（账号若暂不可用 Gemini Image）
# recraft/recraft-v4.1-utility 或 recraft/recraft-v4.1
# 有模特参考时：先用上方文本模型看图写细节，再交给 Recraft 文生图
AI_MODEL_GATEWAY_IMAGE=recraft/recraft-v4.1-utility

# ── B 区视角图生图 Provider（与 AI_PROVIDER 分离）────────────────
# auto = 按 fallback 顺序尝试；也可固定 gateway | siliconflow | dashscope
AI_IMAGE_PROVIDER=auto
AI_IMAGE_FALLBACK=gateway,siliconflow,dashscope
# 有参考图且保真仍不够时，可优先硅基图生图：
# AI_IMAGE_FALLBACK_WITH_REF=siliconflow,gateway,dashscope

# ── 推荐最小配置 ──────────────────────────────────────────
# 必填：
#   AI_GATEWAY_API_KEY          → 文本看图 + Recraft 生图
# 可选备用：
#   SILICONFLOW_API_KEY         → Gateway 失败时回退
# 仅测硅基时可：
#   AI_IMAGE_PROVIDER=siliconflow

# 硅基流动（备用，https://cloud.siliconflow.cn/account/ak）
SILICONFLOW_API_KEY=
# 主模型：Qwen-Image-Edit 适合参考图视角补全；失败时自动回退 Kolors
AI_MODEL_SILICONFLOW_IMAGE=Qwen/Qwen-Image-Edit-2509

# 通义 Dashscope（可选，生图 fallback）
DASHSCOPE_API_KEY=
AI_MODEL_DASHSCOPE=qwen-plus

# 智谱（可选）
ZHIPU_API_KEY=
AI_MODEL_ZHIPU=glm-4-flash
