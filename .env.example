# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://你的项目.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key
SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# ── AI 路由 ──────────────────────────────────────────────
AI_PROVIDER=gateway

# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# 文本任务 + 看图提炼服装规格（非生图）
AI_MODEL_GATEWAY=google/gemini-2.5-flash

# Gateway 生图：Recraft（当前账号以 Recraft 为准）
AI_MODEL_GATEWAY_IMAGE=recraft/recraft-v4.1-utility
# 线稿可单独指定（可选）。若 Gateway 有向量模型可试：
# recraft/recraft-v4.1-utility-vector 或 recraft/recraft-v3
# AI_MODEL_GATEWAY_IMAGE_LINE_ART=recraft/recraft-v4.1-utility

# ── B 区视角图生图 ────────────────────────────────────────
# 默认仅 Gateway；不要回退硅基时保持 gateway 或只写 gateway
AI_IMAGE_PROVIDER=auto
AI_IMAGE_FALLBACK=gateway

# 硅基流动（可选备用；默认不启用）
SILICONFLOW_API_KEY=
AI_MODEL_SILICONFLOW_IMAGE=Qwen/Qwen-Image-Edit-2509

DASHSCOPE_API_KEY=
AI_MODEL_DASHSCOPE=qwen-plus

ZHIPU_API_KEY=
AI_MODEL_ZHIPU=glm-4-flash
